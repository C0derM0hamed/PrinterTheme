{% extends 'layouts/master.twig' %}

{% block title %}{{ post.title }} — {{ store.name }}{% endblock %}
{% block description %}{{ post.excerpt | default(post.content | striptags | slice(0, 160)) }}{% endblock %}

{% block head %}
  {{ parent() }}
  {% if post.image %}<meta property="og:image" content="{{ post.image }}">{% endif %}
  <meta property="og:type" content="article">
  {% if post.created_at %}<meta property="article:published_time" content="{{ post.created_at }}">{% endif %}
{% endblock %}

{% block content %}

<nav class="breadcrumb-bar" aria-label="{{ 'nav.breadcrumb' | t | default('Breadcrumb') }}">
  <div class="container-fluid px-xl-5">
    <ol class="breadcrumb mb-0 py-3">
      <li class="breadcrumb-item"><a href="{{ store.url }}">{{ 'nav.home' | t | default('Home') }}</a></li>
      <li class="breadcrumb-item"><a href="/blogs">{{ 'blog.title' | t | default('Blog') }}</a></li>
      <li class="breadcrumb-item active" aria-current="page">{{ post.title | slice(0, 40) }}{% if post.title | length > 40 %}…{% endif %}</li>
    </ol>
  </div>
</nav>

<div class="container-fluid px-xl-5 py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">

      {# Category badge #}
      {% if post.category is defined and post.category %}
        <a href="{{ post.category.url }}" class="badge badge-primary mb-3">{{ post.category.name }}</a>
      {% endif %}

      {# Title #}
      <h1 class="blog-single__title mb-3">{{ post.title }}</h1>

      {# Meta #}
      <div class="blog-single__meta d-flex align-items-center text-muted small mb-4">
        {% if post.author is defined and post.author %}
          <span class="mr-3">
            <i class="fa fa-user mr-1" aria-hidden="true"></i>{{ post.author.name }}
          </span>
        {% endif %}
        <span class="mr-3">
          <i class="fa fa-calendar-alt mr-1" aria-hidden="true"></i>{{ post.created_at | date('d M Y') }}
        </span>
        <span>
          <i class="fa fa-clock mr-1" aria-hidden="true"></i>{{ post.reading_time | default(3) }} {{ 'blog.min_read' | t | default('min read') }}
        </span>
      </div>

      {# Featured image #}
      {% if post.image %}
        <div class="blog-single__hero mb-4 rounded-12 overflow-hidden">
          <img src="{{ post.image }}" alt="{{ post.title }}" class="img-fluid w-100" loading="eager" style="max-height:480px;object-fit:cover;">
        </div>
      {% endif %}

      {# Body #}
      <div class="blog-single__body prose">
        {{ post.content | raw }}
      </div>

      {# Tags #}
      {% if post.tags is defined and post.tags | length %}
        <div class="blog-single__tags mt-5 pt-4 border-top">
          {% for tag in post.tags %}
            <a href="/blogs?tag={{ tag.slug }}" class="badge badge-light border mr-1 mb-1">{{ tag.name }}</a>
          {% endfor %}
        </div>
      {% endif %}

      {# Share #}
      <div class="blog-single__share mt-5 pt-4 border-top d-flex align-items-center">
        <span class="text-muted small mr-3">{{ 'common.share' | t | default('Share:') }}</span>
        <a href="https://twitter.com/intent/tweet?url={{ post.url | url_encode }}&text={{ post.title | url_encode }}"
           target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary mr-2" aria-label="Twitter">
          <i class="fa-brands fa-twitter" aria-hidden="true"></i>
        </a>
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ post.url | url_encode }}"
           target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary mr-2" aria-label="Facebook">
          <i class="fa-brands fa-facebook-f" aria-hidden="true"></i>
        </a>
        <a href="https://wa.me/?text={{ post.title | url_encode }}%20{{ post.url | url_encode }}"
           target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary" aria-label="WhatsApp">
          <i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
        </a>
      </div>

      {# Back link #}
      <div class="mt-4">
        <a href="/blogs" class="btn btn-outline-secondary btn-sm">
          <i class="fa fa-arrow-left mr-2" aria-hidden="true"></i>
          {{ 'blog.back_to_blog' | t | default('Back to Blog') }}
        </a>
      </div>

    </div>
  </div>
</div>

{# Related posts #}
{% if related_posts is defined and related_posts | length > 0 %}
  <section class="section-related py-5 bg-light mt-5">
    <div class="container-fluid px-xl-5">
      <h2 class="section-head__title text-center mb-5">{{ 'blog.related' | t | default('Related Articles') }}</h2>
      <div class="row">
        {% for rp in related_posts | slice(0, 3) %}
          <div class="col-md-4 mb-4">
            <article class="blog-card card border-0 shadow-sm rounded-12 h-100">
              {% if rp.image %}
                <a href="{{ rp.url }}" tabindex="-1" aria-hidden="true">
                  <img src="{{ rp.image | image_resize(480, 270) }}" alt="{{ rp.title }}" loading="lazy" class="card-img-top blog-card__img">
                </a>
              {% endif %}
              <div class="card-body p-4">
                <h3 class="blog-card__title h6 font-weight-600 mb-2">
                  <a href="{{ rp.url }}" class="text-dark stretched-link">{{ rp.title }}</a>
                </h3>
                <span class="text-muted x-small">{{ rp.created_at | date('d M Y') }}</span>
              </div>
            </article>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% endblock %}

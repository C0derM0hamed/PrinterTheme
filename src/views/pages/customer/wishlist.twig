{% extends 'layouts/master.twig' %}

{% block title %}{{ 'wishlist.title' | t | default('Wishlist') }} — {{ store.name }}{% endblock %}

{% block content %}

<nav class="breadcrumb-bar" aria-label="{{ 'nav.breadcrumb' | t | default('Breadcrumb') }}">
  <div class="container-fluid px-xl-5">
    <ol class="breadcrumb mb-0 py-3">
      <li class="breadcrumb-item"><a href="{{ store.url }}">{{ 'nav.home' | t | default('Home') }}</a></li>
      <li class="breadcrumb-item active" aria-current="page">{{ 'wishlist.title' | t | default('Wishlist') }}</li>
    </ol>
  </div>
</nav>

<div class="container-fluid px-xl-5 py-5">
  <div class="row">

    <div class="col-lg-3 mb-4 mb-lg-0">
      <div class="account-sidebar card border-0 shadow-sm rounded-12">
        <div class="card-body p-0">
          <nav class="account-sidebar__nav">
            <a href="/profile"       class="account-sidebar__link"><i class="fa fa-user mr-2" aria-hidden="true"></i>{{ 'account.profile' | t | default('Profile') }}</a>
            <a href="/orders"        class="account-sidebar__link"><i class="fa fa-box mr-2" aria-hidden="true"></i>{{ 'account.orders' | t | default('Orders') }}</a>
            <a href="/wishlist"      class="account-sidebar__link is-active"><i class="fa fa-heart mr-2" aria-hidden="true"></i>{{ 'wishlist.title' | t | default('Wishlist') }}</a>
            <a href="/notifications" class="account-sidebar__link"><i class="fa fa-bell mr-2" aria-hidden="true"></i>{{ 'account.notifications' | t | default('Notifications') }}</a>
            <a href="/logout"        class="account-sidebar__link account-sidebar__link--danger"><i class="fa fa-sign-out-alt mr-2" aria-hidden="true"></i>{{ 'auth.logout' | t | default('Logout') }}</a>
          </nav>
        </div>
      </div>
    </div>

    <div class="col-lg-9">
      <h1 class="h4 mb-4 font-weight-600">{{ 'wishlist.title' | t | default('My Wishlist') }}</h1>

      {% if wishlist is defined and wishlist | length > 0 %}
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
          {% for item in wishlist %}
            <div class="col">
              {% include 'components/product/card.twig' with { product: item, show_wishlist_remove: true } %}
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state text-center py-6">
          <div class="empty-state__icon">
            <i class="fa fa-heart" aria-hidden="true"></i>
          </div>
          <h2 class="empty-state__title">{{ 'wishlist.empty_title' | t | default('Your wishlist is empty') }}</h2>
          <p class="empty-state__body">{{ 'wishlist.empty_body' | t | default('Save items you love to find them easily later.') }}</p>
          <a href="/products" class="btn btn-primary btn-lg mt-3">
            {{ 'cart.start_shopping' | t | default('Start Shopping') }}
          </a>
        </div>
      {% endif %}
    </div>

  </div>
</div>

{% endblock %}

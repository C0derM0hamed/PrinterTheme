{#
  Home — static shell (always renders preview without empty composer slots).
  Merchants customize via Featured / Latest feeds + twilight Features.
#}
{% extends 'layouts/master.twig' %}

{% block title %}{{ store.name }}{% endblock %}
{% block description %}{{ store.description | default(store.name) }}{% endblock %}

{% block content %}

  {% if theme.settings.get('show_hero_slider') is not same as(false) %}
    {% include 'components/home/hero.twig' ignore missing %}
  {% endif %}

  {% include 'components/home/features.twig' ignore missing %}
  {% include 'components/home/categories-grid.twig' ignore missing %}
  {% include 'components/home/featured-products.twig' ignore missing %}
  {% include 'components/home/latest-products.twig' ignore missing %}

{% endblock %}

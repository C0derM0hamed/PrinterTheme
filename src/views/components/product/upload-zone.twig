{#
  Upload Zone — components/product/upload-zone.twig (enhanced)
  -------------------------------------------------------------
  Enhanced file upload drop-zone for print shop design files.

  Features:
  - 220px min-height drop area with animated gradient border on hover/drag.
  - Animated cloud upload icon (CSS animation in main.css).
  - Accepted formats shown as chips below the icon.
  - Image previews render inline thumbnail; non-image files (PDF/AI/PSD/EPS/SVG)
    render a file-type badge icon instead.
  - Multi-step status: idle → reading → uploading (progress bar) → uploaded
    (green check + filename + replace/remove CTA).
  - Tries salla.uploader.upload(); falls back to plain <input type="file">
    attached to the add-to-cart form.  The JS feature-detects this at runtime.
  - ARIA live region keeps screen-reader users informed of state changes.
  - All max_upload_mb / accepted_file_types read from theme settings.

  Consumed by:  product/single.twig (guarded by enable_file_upload setting).
  Driven by:    product.js  →  UploadZone state machine.
#}

{% set _max_mb        = theme.settings.get('max_upload_mb')      | default(50) %}
{% set _accept_types  = theme.settings.get('accepted_file_types') | default('.pdf,.ai,.psd,.png,.jpg,.jpeg,.eps,.svg') %}

<div class="upload-zone-wrapper mt-4" id="upload-zone-wrapper">

  <label class="upload-zone-label d-flex align-items-center mb-3">
    <span class="upload-zone-label__icon">
      <i class="fa fa-cloud-upload text-primary" aria-hidden="true"></i>
    </span>
    <span class="ml-2 font-weight-semibold">
      {{ 'product.upload_design' | t | default('Upload Design File') }}
    </span>
    <span class="badge badge-secondary ml-2">{{ 'common.optional' | t | default('Optional') }}</span>
  </label>

  {# ── Drop Zone ────────────────────────────────────────────────── #}
  <div class="upload-zone"
       id="upload-zone"
       role="button"
       tabindex="0"
       aria-describedby="upload-zone-hint"
       aria-label="{{ 'product.drop_file' | t | default('Drop file here or click to browse') }}">

    {# Hidden file input — always present as fallback #}
    <input
      type="file"
      id="file-input"
      name="design_file"
      accept="{{ _accept_types }}"
      aria-hidden="true"
      tabindex="-1"
      style="display:none;">
    <input type="hidden" id="upload-file-id" name="upload_file_id">

    {# ── Idle state ──────────────────────────────────────────────── #}
    <div id="drop-message" class="upload-zone__idle">
      <span class="upload-zone__cloud-icon" aria-hidden="true">
        <i class="fa fa-cloud-upload fa-3x"></i>
      </span>
      <p class="upload-zone__cta mb-1">
        <strong>{{ 'product.drop_file' | t | default('Drop your file here') }}</strong>
        {{ 'common.or' | t | default('or') }}
        <button type="button" class="btn btn-link p-0 align-baseline" id="browse-btn">
          {{ 'product.browse_file' | t | default('browse') }}
        </button>
      </p>
      <p id="upload-zone-hint" class="upload-zone__hint mb-0">
        {{ 'product.max_size' | t | default('Max') }} {{ _max_mb }}MB
      </p>
      {# Format chips #}
      <div class="upload-zone__formats mt-2" aria-label="{{ 'product.accepted_formats' | t | default('Accepted formats') }}">
        {% for fmt in _accept_types | split(',') %}
          <span class="format-chip">{{ fmt | trim | replace({'.': ''}) | upper }}</span>
        {% endfor %}
      </div>
    </div>

    {# ── Active / preview state (hidden until file selected) ─────── #}
    <div id="file-preview" class="upload-zone__preview d-none">

      {# Image thumbnail or filetype badge #}
      <div class="upload-preview-media mb-2">
        <img id="preview-img"
             src=""
             alt="{{ 'product.design_preview' | t | default('Design preview') }}"
             class="upload-preview-img rounded d-none"
             style="max-height:120px; max-width:100%; object-fit:contain;">
        <div id="preview-badge" class="upload-filetype-badge d-none">
          <i class="fa fa-file-text fa-3x text-primary" aria-hidden="true"></i>
        </div>
      </div>

      <p id="file-name" class="font-weight-semibold mb-0 text-truncate" style="max-width:260px;"></p>
      <small id="file-size" class="text-muted d-block mb-2"></small>

      {# Progress bar (hidden until upload starts) #}
      <div id="upload-progress" class="progress mb-2" style="height:6px; display:none;" role="progressbar"
           aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
        <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
             id="upload-progress-bar"
             style="width:0%"></div>
      </div>

      {# ARIA live region for status changes #}
      <span id="upload-status"
            class="upload-status d-block mb-2"
            role="status"
            aria-live="polite"></span>

      {# Action buttons #}
      <div class="d-flex mt-1">
        <button type="button" class="btn btn-sm btn-outline-secondary mr-2" id="replace-file">
          <i class="fa fa-refresh mr-1" aria-hidden="true"></i>
          {{ 'product.replace_file' | t | default('Replace') }}
        </button>
        <button type="button" class="btn btn-sm btn-outline-danger" id="remove-file">
          <i class="fa fa-trash mr-1" aria-hidden="true"></i>
          {{ 'product.remove_file' | t | default('Remove') }}
        </button>
      </div>

    </div>{# /#file-preview #}
  </div>{# /.upload-zone #}

  {# Hint text below the zone #}
  <p class="text-muted mt-2 mb-0" style="font-size:var(--fs-12);">
    <i class="fa fa-info-circle mr-1" aria-hidden="true"></i>
    {{ 'product.upload_hint' | t | default('You can also submit the order first and send the design file later via WhatsApp or email.') }}
  </p>

</div>{# /.upload-zone-wrapper #}
